# PaiCLI 配置示例
# 用法：
# 1. 复制本文件为 .env
# 2. 按需填写下面的配置项
# 3. 未填写的项会回退到代码默认值

# 主模型 API Key
# 用于 ReAct / Plan-and-Execute 主对话请求
# 如果当前目录 .env 未设置，会继续尝试用户主目录 ~/.env 和环境变量 GLM_API_KEY
# GLM_API_KEY=your_real_api_key_here

GLM_API_KEY=your_api_key_here

# Embedding 配置（用于 /index、/search、Agent 的代码检索）
# 支持 provider：ollama / openai / zhipu / glm
# 不配置时默认使用 ollama + nomic-embed-text:latest + http://localhost:11434
EMBEDDING_PROVIDER=ollama
EMBEDDING_MODEL=nomic-embed-text:latest
EMBEDDING_BASE_URL=http://localhost:11434

# 如果使用需要鉴权的远程 Embedding 服务，再打开这一项
# EMBEDDING_API_KEY=your_api_key_here

# 日志配置（支持自动滚动、压缩和清理）
# 默认日志目录：~/.paicli/logs
# 默认日志文件：~/.paicli/logs/paicli.log
# 日志级别可选：ERROR / WARN / INFO / DEBUG
PAICLI_LOG_LEVEL=INFO

# 日志目录。建议填绝对路径
PAICLI_LOG_DIR=/Users/yourname/.paicli/logs

# 最多保留多少天的历史日志
PAICLI_LOG_MAX_HISTORY=7

# 单个日志文件滚动前的最大体积
PAICLI_LOG_MAX_FILE_SIZE=10MB

# 所有归档日志允许占用的总容量，超出后会自动清理更老的日志
PAICLI_LOG_TOTAL_SIZE_CAP=100MB
